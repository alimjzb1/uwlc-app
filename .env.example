VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Fleetrunnr API Integration
# Instructions:
# 1. Log in to your Fleetrunnr admin dashboard
# 2. Go to Settings -> API Keys (or Developer Settings)
# 3. Generate a new API Key with Read permissions for Orders/Tracking
# 4. Copy the key and paste it below in your actual .env file
VITE_FLEETRUNNR_API_KEY=
